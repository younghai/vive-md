{
  "name": "crm-service",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "CRM service generated from docs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "env:check": "node --import ../../node_modules/tsx/dist/esm/index.mjs scripts/env-check.ts",
    "contract:audit": "node --import ../../node_modules/tsx/dist/esm/index.mjs scripts/contract-audit.ts",
    "postman:generate": "tsx scripts/generate-postman.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@vive-crm/shared": "*",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "hono": "^4.6.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/node": "^22.9.0",
    "prisma": "^5.22.0",
    "tsx": "^4.18.0",
    "vitest": "^2.1.4",
    "typescript": "^5.6.3"
  }
}
