generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ContactGrade {
  HOT
  WARM
  COLD
}

enum DealStage {
  LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  contacts Contact[]
  deals    Deal[]
  activities Activity[]
  tasks    Task[]
  leadScores LeadScore[]
  leadScoreHistory LeadScoreHistory[]
  refreshTokens RefreshToken[]
  dealStageHistory DealStageHistory[]
}

model Contact {
  id          String       @id @default(uuid())
  ownerId     String
  name        String
  email       String?
  phone       String?
  company     String?
  leadGrade   String?
  leadScore   Int?
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  owner User @relation(fields: [ownerId], references: [id])
  deals    Deal[]
  activities Activity[]
  tasks    Task[]
  leadScores LeadScore[]
  leadScoreHistory LeadScoreHistory[]

  @@index([ownerId])
}

model Deal {
  id        String     @id @default(uuid())
  ownerId   String
  title     String
  amount    Int        @default(0)
  probability Int      @default(0)
  stage     DealStage  @default(LEAD)
  expectedCloseDate DateTime?
  contactId String?
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  owner User @relation(fields: [ownerId], references: [id])
  contact Contact? @relation(fields: [contactId], references: [id])
  activities Activity[]
  tasks Task[]
  histories DealStageHistory[]

  @@index([ownerId])
  @@index([stage])
}

model Activity {
  id        String       @id @default(uuid())
  ownerId   String
  contactId String?
  dealId    String?
  type      ActivityType @default(NOTE)
  title     String
  note      String?
  scheduledAt DateTime?
  performedAt DateTime?
  deletedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  owner User @relation(fields: [ownerId], references: [id])
  contact Contact? @relation(fields: [contactId], references: [id])
  deal Deal? @relation(fields: [dealId], references: [id])

  @@index([ownerId])
}

model Task {
  id        String       @id @default(uuid())
  ownerId   String
  contactId String?
  dealId    String?
  title     String
  note      String?
  priority  TaskPriority @default(MEDIUM)
  dueDate   DateTime?
  completedAt DateTime?
  deletedAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  owner User @relation(fields: [ownerId], references: [id])
  contact Contact? @relation(fields: [contactId], references: [id])
  deal Deal? @relation(fields: [dealId], references: [id])

  @@index([ownerId])
  @@index([dueDate])
}

model LeadScore {
  id        String   @id @default(uuid())
  userId    String
  contactId String   @unique
  score     Int
  summary   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])
}

model LeadScoreHistory {
  id        String   @id @default(uuid())
  userId    String
  contactId String
  score     Int
  summary   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  contact Contact @relation(fields: [contactId], references: [id])
}

model DealStageHistory {
  id        String   @id @default(uuid())
  dealId    String
  userId    String
  fromStage DealStage
  toStage   DealStage
  createdAt DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  userAgent String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}
